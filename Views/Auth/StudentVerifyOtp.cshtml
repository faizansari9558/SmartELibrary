@model SmartELibrary.ViewModels.StudentVerifyOtpViewModel
@{
    ViewData["Title"] = "Verify OTP";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <h4 class="mb-3">Verify Student OTP</h4>
                @if (TempData["DebugOtp"] is not null)
                {
                    <div class="alert alert-info">Demo OTP: <strong>@TempData["DebugOtp"]</strong></div>
                }
                <form asp-action="StudentVerifyOtp" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    <div class="mb-2">
                        <label asp-for="PhoneNumber" class="form-label">Mobile Number</label>
                        <input asp-for="PhoneNumber" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label asp-for="OtpCode" class="form-label">OTP</label>
                        <input asp-for="OtpCode" class="form-control" maxlength="6" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Verify OTP</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
