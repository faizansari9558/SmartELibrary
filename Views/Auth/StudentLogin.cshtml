@model SmartELibrary.ViewModels.StudentLoginViewModel
@{
    ViewData["Title"] = "Student Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <h4 class="mb-1">Student Login</h4>
                <p class="mb-3">Enter mobile number and password to receive OTP</p>
                <form asp-action="StudentLogin" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label">Mobile Number</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Generate OTP</button>
                </form>
                <div class="mt-3 text-center">
                    New to Smart E-Library? <a asp-controller="Account" asp-action="RegisterStudent">Register here</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
