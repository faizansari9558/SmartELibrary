@model SmartELibrary.Models.Material
@{
    ViewData["Title"] = "Read Material";
}

<div class="card">
    <div class="card-body">
        <h5>@Model.Title</h5>
        <p class="text-muted">@Model.Subject?.Name - @Model.Semester?.Name</p>

        <div class="read-landscape readonly-content" id="readerArea">
            @if (Model.MaterialType == SmartELibrary.Models.MaterialType.Pdf)
            {
                <iframe src="@Model.FilePathOrUrl" style="width:100%;height:65vh;border:none;"></iframe>
            }
            else if (Model.MaterialType == SmartELibrary.Models.MaterialType.Image)
            {
                <img src="@Model.FilePathOrUrl" class="img-fluid" alt="Material image" />
            }
            else if (Model.MaterialType == SmartELibrary.Models.MaterialType.ExternalLink)
            {
                <a href="@Model.FilePathOrUrl" target="_blank">Open external resource</a>
            }
            else
            {
                <a href="@Model.FilePathOrUrl" target="_blank">Open material</a>
            }
        </div>

        <div class="mt-3 d-flex gap-2">
            <a class="btn btn-outline-primary" asp-action="Library">Back Library</a>
        </div>
    </div>
</div>
