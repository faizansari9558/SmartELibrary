@{
    ViewData["Title"] = "Waiting for Semester Approval";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h4 class="mb-2">Waiting for Semester Approval</h4>
                <p class="text-muted">Your semester enrollment is pending. Digital Library access will be available after an admin approves at least one semester.</p>
                <div class="d-flex gap-2">
                    <a class="btn btn-primary" asp-action="EnrollSemester">Enroll Semester</a>
                    <a class="btn btn-outline-secondary" asp-action="Dashboard">Back to Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</div>
