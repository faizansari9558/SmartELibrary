@model SmartELibrary.ViewModels.ProgressAnalyticsDashboardViewModel
@{
    ViewData["Title"] = "System Reports";
}

<div class="row g-3">
    <div class="col-12">
        <div class="card">
            <div class="card-body table-responsive">
                <h6 class="mb-3">Student Progress Analytics</h6>
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                    <tr>
                        <th class="text-nowrap" style="width: 140px;">Enrollment No</th>
                        <th class="text-nowrap">Student Name</th>
                        <th class="text-nowrap" style="width: 140px;">Semester</th>
                        <th class="text-end text-nowrap" style="width: 150px;">Screen Time</th>
                        <th class="text-end text-nowrap" style="width: 140px;">Quiz Score (%)</th>
                        <th class="text-end text-nowrap" style="width: 110px;">Quiz Marks</th>
                        <th class="text-end text-nowrap" style="width: 140px;">Completion (%)</th>
                        <th style="min-width: 220px;">Final Progress (%)</th>
                        <th class="text-nowrap" style="width: 140px;">Status</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">No progress records found.</td></tr>
                    }
                    else
                    {
                        foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td class="text-nowrap">@row.EnrollmentNo</td>
                                <td class="text-nowrap">@row.StudentName</td>
                                <td class="text-nowrap">@row.Semester</td>
                                <td class="text-end text-nowrap">@row.ScreenTimeHms</td>
                                <td class="text-end text-nowrap">@row.QuizScorePercent</td>
                                <td class="text-end text-nowrap">@row.QuizMarks</td>
                                <td class="text-end text-nowrap">@row.CompletionPercent</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height: 10px;">
                                            <div class="progress-bar @row.ProgressBarClass" role="progressbar" style="width: @row.FinalProgressPercent%" aria-valuenow="@row.FinalProgressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <div class="text-nowrap">@row.FinalProgressPercent%</div>
                                    </div>
                                </td>
                                <td class="text-nowrap"><span class="badge bg-secondary">@row.Status</span></td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
